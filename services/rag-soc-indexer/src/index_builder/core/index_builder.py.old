#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
Core index building logic
"""

import os
import time
import shutil
from pathlib import Path
from typing import List, Optional, Dict, Any, Tuple
import logging

import chromadb
import torch
from sentence_transformers import SentenceTransformer

from ..parsers.json_parser import JSONParser
from ..core.chunking_strategies import SizeBasedChunking, StructureBasedChunking
from ..models.schemas import ProcessingStats


class IndexBuilder:
    def __init__(
        self,
        source_folder: Path,
        persist_dir: Path,
        meta_folder: Optional[Path] = None,
        model_path: Optional[str] = None,
        model_name: Optional[str] = None,
        chunk_size: int = 900,
        chunk_overlap: int = 150,
        chunk_by_structure: bool = False,
        use_cleaner: bool = True,  # kept for compatibility, ignored for JSON
        logger: Optional[logging.Logger] = None
    ):
        self.source_folder = source_folder
        self.meta_folder = meta_folder or source_folder  # если не указана, ищем в той же папке
        self.persist_dir = persist_dir
        self.model_path = model_path
        self.model_name = model_name
        self.chunk_size = chunk_size
        self.chunk_overlap = chunk_overlap
        self.chunk_by_structure = chunk_by_structure
        self.logger = logger or logging.getLogger(__name__)

        # Инициализация компонентов
        self.json_parser = JSONParser(self.logger)

        # Стратегии чанкования
        self.size_chunker = SizeBasedChunking(chunk_size, chunk_overlap, self.logger)
        self.structure_chunker = StructureBasedChunking(self.logger)

        # Модель эмбеддингов (будет загружена позже)
        self.embed_model = None
        self.embed_model_name = None

        # Статистика
        self.stats = ProcessingStats()

    def load_embedding_model(self):
        """Загружает модель эмбеддингов"""
        # prefer local path if exists
        if self.model_path and os.path.exists(self.model_path):
            self.logger.info(f" 📂 Loading local embedding model from: {self.model_path}")
            self.embed_model = SentenceTransformer(self.model_path)
            self.embed_model_name = self.model_path
        else:
            model_name = self.model_name or "sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2"
            self.logger.info(f"🌐 Loading embedding model: {model_name}")
            self.embed_model = SentenceTransformer(model_name)
            self.embed_model_name = model_name

        device = "cuda" if torch.cuda.is_available() else "cpu"
        self.embed_model.to(device)
        self.logger.info(f"✅ Embedding model loaded ({self.embed_model_name}), device={device}, "
                        f"dim={self.embed_model.get_sentence_embedding_dimension()}")

    def collect_json_files(self) -> List[Path]:
        """Собирает все JSON файлы данных в папке source_folder"""
        json_files = []
        for p in self.source_folder.iterdir():
            if p.suffix.lower() == ".json" and self.json_parser.is_data_json(p):
                json_files.append(p)

        self.logger.info(f"📁 Found {len(json_files)} JSON content files in {self.source_folder}")
        return json_files

    def find_metadata_file(self, content_filename: str) -> Optional[Path]:
        """Находит соответствующий файл метаданных для файла контента"""
        # Ищем в meta_folder файл с таким же именем
        metadata_path = self.meta_folder / content_filename

        if metadata_path.exists():
            self.logger.debug(f"Found metadata: {metadata_path}")
            return metadata_path

        # Если не нашли, пробуем другие варианты (на всякий случай)
        stem = Path(content_filename).stem
        for p in self.meta_folder.glob(f"*{stem}*.json"):
            self.logger.debug(f"Found metadata by pattern: {p}")
            return p

        self.logger.debug(f"No metadata found for {content_filename}")
        return None

    def enrich_metadata_from_json(self, data_json: Dict[str, Any], metadata_json: Optional[Dict[str, Any]]) -> Dict[str, Any]:
        """Обогащает метаданные из JSON и приводит их к типам, совместимым с ChromaDB"""
        base_meta = {}

        # Базовая информация из данных (все в строки)
        data_metadata = data_json.get("metadata", {})
        base_meta["source_file"] = str(data_metadata.get("source_file", "unknown"))
        base_meta["title"] = str(data_metadata.get("article_title", "unknown"))

        # Расширенная информация из метаданных (если есть)
        if metadata_json:
            self.logger.debug(f"Enriching with metadata: {metadata_json.get('metadata_version', 'unknown')}")

            # Иерархия - преобразуем в строку
            hierarchy = metadata_json.get("article", {}).get("hierarchy", [])
            hierarchy_titles = [str(h.get("title", "")) for h in hierarchy if h.get("title")]
            base_meta["hierarchy_path"] = " > ".join(hierarchy_titles) if hierarchy_titles else ""

            # DC Identifier и тип документа - в строки
            base_meta["dc_identifier"] = str(metadata_json.get("article", {}).get("dc_identifier", ""))
            base_meta["document_type"] = str(metadata_json.get("article", {}).get("document_type", ""))

            # Технические метаданные - ВАЖНО: преобразуем списки в строки с разделителем
            tech_meta = metadata_json.get("technical_metadata", {})

            # Версии прошивок - список преобразуем в строку через запятую
            fw_versions = tech_meta.get("firmware_versions", {})
            versions_str = ""
            if isinstance(fw_versions, dict):
                all_versions = fw_versions.get("all_versions", [])
                primary = fw_versions.get("primary", "")
                versions = []
                if primary:
                    versions.append(str(primary))
                for v in all_versions:
                    if v and str(v) not in versions:
                        versions.append(str(v))
                versions_str = ", ".join(versions) if versions else ""
            elif isinstance(fw_versions, list):
                versions_str = ", ".join([str(v) for v in fw_versions if v])
            base_meta["firmware_versions"] = versions_str

            # Платформы - список преобразуем в строку через запятую
            platforms = tech_meta.get("platforms", {})
            platforms_str = ""
            if isinstance(platforms, dict):
                compatible = platforms.get("compatible_models", [])
                product_series = platforms.get("product_series", "")
                platform_list = []
                if product_series:
                    platform_list.append(str(product_series))
                for p in compatible:
                    if p and str(p) not in platform_list:
                        platform_list.append(str(p))
                platforms_str = ", ".join(platform_list) if platform_list else ""
            elif isinstance(platforms, list):
                platforms_str = ", ".join([str(p) for p in platforms if p])
            base_meta["platforms"] = platforms_str

            # Связи между статьями - все в строки
            relations = metadata_json.get("relations", {})

            parent = relations.get("parent_article", {})
            if isinstance(parent, dict):
                base_meta["parent_article_title"] = str(parent.get("title", ""))
                base_meta["parent_article_md"] = str(parent.get("md_filename", ""))

            prev = relations.get("previous_article", {})
            if isinstance(prev, dict):
                base_meta["previous_article_title"] = str(prev.get("title", ""))
                base_meta["previous_article_md"] = str(prev.get("md_filename", ""))

            nxt = relations.get("next_article", {})
            if isinstance(nxt, dict):
                base_meta["next_article_title"] = str(nxt.get("title", ""))
                base_meta["next_article_md"] = str(nxt.get("md_filename", ""))
        else:
            self.logger.debug(f"No metadata found for {base_meta['source_file']}, using basic metadata only")
            # Инициализируем пустыми строками все поля, которые ожидаются
            base_meta["hierarchy_path"] = ""
            base_meta["dc_identifier"] = ""
            base_meta["document_type"] = ""
            base_meta["firmware_versions"] = ""
            base_meta["platforms"] = ""
            base_meta["parent_article_title"] = ""
            base_meta["parent_article_md"] = ""
            base_meta["previous_article_title"] = ""
            base_meta["previous_article_md"] = ""
            base_meta["next_article_title"] = ""
            base_meta["next_article_md"] = ""

        # Убеждаемся, что все значения - строки или None (для ChromaDB)
        clean_meta = {}
        for key, value in base_meta.items():
            if value is None:
                clean_meta[key] = ""
            elif isinstance(value, (list, dict)):
                # Если вдруг остался список или словарь - преобразуем в JSON строку
                import json
                clean_meta[key] = json.dumps(value, ensure_ascii=False)
            else:
                clean_meta[key] = str(value)

        return clean_meta

    def process_file(self, json_path: Path) -> List[Tuple[str, Dict[str, Any]]]:
        """Обрабатывает один JSON файл и возвращает чанки"""
        self.logger.debug(f"Processing {json_path.name}")

        # Загружаем данные
        data_json = self.json_parser.load_json_file(json_path)
        if not data_json:
            self.stats.files_with_errors.append(str(json_path))
            return []

        # Ищем соответствующий файл метаданных
        metadata_path = self.find_metadata_file(json_path.name)
        metadata_json = None
        if metadata_path:
            metadata_json = self.json_parser.load_metadata(metadata_path)
            if metadata_json:
                self.logger.debug(f"Loaded metadata: {metadata_path.name}")

        # Обогащаем метаданные
        base_metadata = self.enrich_metadata_from_json(data_json, metadata_json)

        # Извлекаем секции из структуры
        sections = self.json_parser.extract_sections(data_json)

        chunks = []
        strategy_name = "structure" if self.chunk_by_structure else "size"

        if self.chunk_by_structure:
            # Чанкование по структуре
            for chunk_text, chunk_meta in self.structure_chunker.chunk(sections, base_metadata):
                chunks.append((chunk_text, chunk_meta))
            self.logger.debug(f"Structure chunking: {len(chunks)} chunks from {len(sections)} sections")
        else:
            # Чанкование по размеру
            # Объединяем весь текст из всех секций
            full_text = "\n\n".join([text for _, text in sections])
            for chunk_text, chunk_meta in self.size_chunker.chunk(full_text, base_metadata):
                chunks.append((chunk_text, chunk_meta))
            self.logger.debug(f"Size chunking: {len(chunks)} chunks from {len(full_text)} chars")

        # Обновляем статистику
        self.stats.total_chunks += len(chunks)
        strategy_key = f"{strategy_name}_chunks"
        self.stats.chunks_by_strategy[strategy_key] = self.stats.chunks_by_strategy.get(strategy_key, 0) + len(chunks)

        return chunks

    def build_index(self) -> bool:
        """Основной метод построения индекса"""
        self.logger.info("🔧 Start building index")

        if not self.source_folder.exists():
            self.logger.error(f"Source folder not found: {self.source_folder}")
            return False

        if not self.meta_folder.exists():
            self.logger.warning(f"Meta folder not found: {self.meta_folder}, will use source folder only")
            self.meta_folder = self.source_folder

        # Загружаем модель эмбеддингов
        self.load_embedding_model()

        # Собираем JSON файлы
        json_files = self.collect_json_files()
        self.stats.total_files = len(json_files)

        if not json_files:
            self.logger.warning("No JSON files found")
            return False

        self.logger.info(f"Processing {len(json_files)} files with metadata from {self.meta_folder}")

        # Обрабатываем все файлы
        corpus_chunks = []
        corpus_metas = []

        for json_path in json_files:
            try:
                chunks = self.process_file(json_path)
                for chunk_text, chunk_meta in chunks:
                    corpus_chunks.append(chunk_text)
                    corpus_metas.append(chunk_meta)
            except Exception as e:
                self.logger.error(f"Error processing {json_path}: {e}", exc_info=True)
                self.stats.files_with_errors.append(str(json_path))

        self.logger.info(f"📦 Total chunks to embed: {len(corpus_chunks)}")

        if not corpus_chunks:
            self.logger.error("No chunks generated")
            return False

        # Генерируем эмбеддинги
        device = "cuda" if torch.cuda.is_available() else "cpu"
        batch_size = 128 if device == "cuda" else 32

        t0 = time.time()
        self.logger.info(f"Generating embeddings with batch size {batch_size}...")

        embeddings = self.embed_model.encode(
            corpus_chunks,
            batch_size=batch_size,
            show_progress_bar=True,
            convert_to_numpy=True,
            normalize_embeddings=True
        )

        t1 = time.time()
        self.stats.processing_time = t1 - t0
        self.logger.info(f"✅ Embeddings: {embeddings.shape} generated in {self.stats.processing_time:.2f}s")

        # Сохраняем в Chroma
        if self.persist_dir.exists():
            self.logger.info(f"ℹ️ Removing existing index at {self.persist_dir}")
            shutil.rmtree(self.persist_dir)

        self.persist_dir.mkdir(parents=True, exist_ok=True)

        client = chromadb.PersistentClient(path=str(self.persist_dir))
        collection = client.get_or_create_collection(
            name="knowledge_base",
            metadata={
                "hnsw:space": "cosine",
                "model": str(self.embed_model_name),
                "chunk_size": str(self.chunk_size),
                "chunk_by_structure": str(self.chunk_by_structure),
                "embedding_dim": str(self.embed_model.get_sentence_embedding_dimension()),
                "source_folder": str(self.source_folder),
                "meta_folder": str(self.meta_folder)
            }
        )

        # Добавляем батчами
        batch = 3000
        for i in range(0, len(corpus_chunks), batch):
            end = min(i + batch, len(corpus_chunks))
            ids = [f"chunk_{j}" for j in range(i, end)]
            emb_batch = embeddings[i:end].tolist()
            docs_batch = corpus_chunks[i:end]
            metas_batch = corpus_metas[i:end]

            collection.add(
                ids=ids,
                embeddings=emb_batch,
                documents=docs_batch,
                metadatas=metas_batch
            )
            self.logger.info(f"➕ Added batch {i}-{end}")

        self.logger.info(f"🎉 Index built and saved at: {self.persist_dir}")
        self.logger.info(f"📊 Statistics: total_files={self.stats.total_files}, total_chunks={self.stats.total_chunks}, "
                        f"errors={len(self.stats.files_with_errors)}, time={self.stats.processing_time:.2f}s")

        return True